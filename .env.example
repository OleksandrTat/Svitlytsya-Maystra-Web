# ─────────────────────────────────────────────────────────────
# Svitlytsya Maystra — variables de entorno
#
# Copia este fichero a .env.local y rellena los valores.
# Las variables marcadas como REQUERIDA son obligatorias para
# que la aplicación arranque.
# ─────────────────────────────────────────────────────────────

# ─── Supabase (REQUERIDO) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xyzcompany.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.service_role_example
SUPABASE_PROJECT_REF=xyzcompany

# Solo si usas la Supabase CLI / scripts de backup directos a la BD.
# SUPABASE_DB_PASSWORD=changeme
# SUPABASE_DB_URL=postgresql://postgres:changeme@db.xyzcompany.supabase.co:5432/postgres
# SUPABASE_DB_POOLER_HOST=aws-0-us-east-1.pooler.supabase.com

# ─── Sitio (REQUERIDO) ────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Server Actions (REQUERIDO en producción) ─────────────────
# Sin esto, Next.js genera un nuevo ID por cada Server Action en
# cada build, lo que rompe las páginas estáticas que ya están en
# caché del CDN cuando despliegas. Genera con:
#   openssl rand -base64 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# ─── OpenAI (opcional) — chatbot, sugerencias, traducciones ──
# OPENAI_API_KEY=sk-...

# ─── Cloudflare Turnstile (opcional) — antibot del formulario─
# TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x0000000000000000000000000000000000000000

# ─── Resend (opcional) — emails transaccionales ──────────────
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=no-reply@example.com
# ADMIN_EMAIL=admin@example.com

# ─── PostHog (opcional) — analítica ──────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...

# ─── Backups a S3 (opcional) — cron diario ───────────────────
# BACKUP_CRON_TOKEN=changeme
# BACKUP_RETENTION_DAYS=30
# BACKUP_S3_BUCKET=svitlytsya-backups
# BACKUP_S3_REGION=eu-central-1
# BACKUP_S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
# BACKUP_S3_PREFIX=prod/
# BACKUP_NOTIFY_EMAIL=
